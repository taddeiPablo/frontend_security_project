extends ../layout

block content
  div(class="flex items-center justify-center min-h-screen bg-gray-50 py-12 px-4")
    div(class="w-full max-w-md")
      div(class="bg-white rounded-lg shadow-md border border-gray-200 p-8")
        h2(class="text-3xl font-bold text-center text-gray-900 mb-2") Crear Cuenta
        p(class="text-center text-gray-600 text-sm mb-8") Únete a nuestra plataforma de seguridad
        
        form(method='POST' action='/auth/register' class="space-y-5")
          div
            label(for='name' class="block text-sm font-semibold text-gray-700 mb-2") Nombre Completo de la empresa
            input(
              type='text'
              id='name'
              name='name'
              required
              placeholder='Juan Pérez'
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
            )
          
          div
            label(for='email' class="block text-sm font-semibold text-gray-700 mb-2") Correo Electrónico
            input(
              type='email'
              id='email'
              name='email'
              required
              placeholder='juan@example.com'
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
            )
          
          div
            label(for='password' class="block text-sm font-semibold text-gray-700 mb-2") Contraseña
            input(
              type='password'
              id='password'
              name='password'
              required
              placeholder='••••••••'
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
            )
            p(class="text-xs text-gray-500 mt-1") Mínimo 8 caracteres
          
          div
            label(for='confirm-password' class="block text-sm font-semibold text-gray-700 mb-2") Confirmar Contraseña
            input(
              type='password'
              id='confirm-password'
              name='confirmPassword'
              required
              placeholder='••••••••'
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
            )
          
          button(type='submit' class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-lg transition duration-200") Registrarse
          
          p(class="text-center text-sm text-gray-600 mt-6")
            | ¿Ya tienes cuenta? 
            a(href='/users/Sign-In' class="font-semibold text-indigo-600 hover:text-indigo-700") Inicia sesión aquí