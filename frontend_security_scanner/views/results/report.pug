doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Security Scan Report
    link(rel="stylesheet", href="/stylesheets/report.css")
  body.report-body
    // ===== COVER PAGE =====
    section.cover-page
      div.cover-container
        div.cover-header
          //img.cover-logo(src="{{agencyLogo}}", alt="Agency Logo")
          h1.cover-title Security Scan Report
          p.cover-subtitle Automated Frontend Security Analysis

        div.cover-main
          h2.cover-heading Frontend Security Report
          
          div.score-wrapper
            div.score-circle.score-medium
              div.score-value #{score}
              div.score-label #{scoreLabel}
          div.cover-meta
              p.meta-item
                span.meta-label Client:
                span.meta-value #{companyName}
              p.meta-item
                span.meta-label Website:
                span.meta-value #{url}
              p.meta-item
                span.meta-label Analysis Date:
                span.meta-value #{reportDate || '‑'}

    // ===== PAGE BREAK =====
    div.page-break

    // ===== MAIN CONTENT =====
    main.report-main
      // ===== HEADER SECTION =====
      header.report-header
        div.header-top
          //div.header-logo
            img(src="{{agencyLogo}}", alt="Agency Logo")
          div.header-info
            h1.header-title Frontend Security Report
            p.header-subtitle Preventive Security Review & Risk Assessment

      // ===== METADATA SECTION =====
      section.metadata-section
        div.metadata-grid
          div.metadata-card
            span.metadata-icon 👤
            h3.metadata-label Client
            p.metadata-value #{companyName}
          
          div.metadata-card
            span.metadata-icon 🌐
            h3.metadata-label Websites
            p.metadata-value #{url}
          
          div.metadata-card
            span.metadata-icon 📅
            h3.metadata-label Date
            p.metadata-value= reportDate || '‑'

      // ===== EXECUTIVE SUMMARY =====
      section.section-summary
        div.section-header
          h2.section-title Executive Summary
          div.section-divider
        
        div.summary-content
          p.summary-text
            | This report presents the results of an automated frontend security analysis performed on the evaluated website.
            | The assessment focused on identifying security misconfigurations, insecure HTTP headers,
            | and JavaScript resource exposure that could represent potential risks before production deployment.
          
          div.analysis-scope
            h4.scope-title Analysis Scope
            ul.scope-list
              li Security policy validation (CSP, X-Frame-Options, etc.)
              li HTTP header configuration review
              li JavaScript resources and build configuration exposure
              li Sensitive information disclosure risks

      // ===== FINDINGS SECTION =====
      section.section-findings
        div.section-header
          h2.section-title Findings Detected
          div.section-divider
        
        div.findings-container
          table.findings-table
            thead.table-header
              tr
                th.col-severity Severity
                th.col-finding Finding
                th.col-impact Impact
            tbody.table-body
              each finding in findings
                tr
                  td.col-severity #{finding.severity}
                  td.col-finding #{finding.description}
                  td.col-impact #{finding.impact}
                // Si el hallazgo tiene solución y es un usuario "Premium" (o para tentar al de la demo)
                if finding.remediation
                  tr
                    td(colspan="3" style="background-color: #f9fafb; padding: 15px;")
                      strong 🛠️ Cómo arreglarlo:
                      p #{finding.remediation.steps}
                      if finding.remediation.code
                        pre
                          code #{finding.remediation.code.express}

      // ===== RECOMMENDATIONS SECTION =====
      section.section-recommendations
        div.section-header
          h2.section-title Recommendations
          div.section-divider
        
        div.recommendations-content
          ul.recommendations-list
            li
              span.rec-icon ✓
              div.rec-item
                strong Implement Security Headers
                p Configure appropriate HTTP security headers to reduce common attack vectors and enforce security policies.
            
            li
              span.rec-icon ✓
              div.rec-item
                strong Secure JavaScript Resources
                p Review and minimize the exposure of JavaScript files, source maps, and build configuration details in production.
            
            li
              span.rec-icon ✓
              div.rec-item
                strong Security Review Process
                p Incorporate automated security reviews as part of your delivery pipeline.
            
            li
              span.rec-icon ✓
              div.rec-item
                strong Manual Audit
                p Schedule periodic manual security assessments to complement automated analysis.

      // ===== NEXT STEPS SECTION =====
      section.section-next-steps
        div.next-steps-card
          h3.next-steps-title Next Steps
          p.next-steps-text
            | This automated report provides a snapshot of potential security issues.
            | We recommend scheduling a detailed technical evaluation for comprehensive remediation planning.
          
          div.next-steps-actions
            p 📧 For support in implementing improvements, contact the security team.
            p 🔍 Consider a complete manual security audit for production systems.

    // ===== FOOTER =====
    footer.report-footer
      div.footer-content
        p.footer-disclaimer
          | This report is based on automated frontend analysis and does not replace a complete manual security audit.
        
        p.footer-info
          | For a deeper review or technical support, we recommend a detailed security evaluation by qualified professionals.
      
      div.footer-bottom
        p.footer-date Report generated: #{reportDate}