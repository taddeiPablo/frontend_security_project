doctype html
html(lang="es")
  head
    title Frontend Security Scanner - Dashboard
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    script(src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4")
    link(rel='stylesheet', href='/stylesheets/style.css')
  
  body.bg-gray-50
    // Contenedor Principal en Flex
    .flex.min-h-screen
      
      // 1. Sidebar Fijo (Izquierda)
      aside.w-64.bg-indigo-700.text-white.flex-shrink-0
        include ../views/navegation/navbar

      // 2. Área de Contenido (Derecha)
      .flex-1.flex.flex-col.min-w-0
        
        // Header Superior
        header.bg-white.border-b.border-gray-200.sticky.top-0.z-10
          .max-w-7xl.mx-auto.px-4.sm.px-6.lg.px-8
            .flex.justify-between.h-16.items-center
              // Branding/Logo para móvil o contexto
              .flex.items-center.gap-2
                span.bg-indigo-600.text-white.px-2.py-1.rounded.font-bold FS
                span.text-gray-900.font-semibold Frontend Scanner
              
              // Botones de sesión/navegación
              nav.flex.items-center.gap-4
                include ./navegation/nav

        // Main Content (El bloque que inyecta cada página)
        main.flex-1.p-6
          .max-w-7xl.mx-auto
            block content

    block scripts
