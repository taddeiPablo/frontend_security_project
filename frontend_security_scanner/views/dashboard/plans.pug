extends ../dashboard-layout

block content
  .container.mx-auto.px-4.py-12
    // Encabezado
    .mb-12.text-center
      h1.text-4xl.font-bold.text-gray-900.mb-4
        | Planes Premium
      p.text-xl.text-gray-600
        | Elige el plan que mejor se ajuste a tus necesidades de seguridad
    
    // Contenedor de Planes
    .grid.grid-cols-1.md.grid-cols-2.lg.grid-cols-3.gap-8.max-w-6xl.mx-auto
      
      // Plan Básico - $free
      .bg-white.rounded-lg.shadow-lg.overflow-hidden.hover.scale-105.transition.duration-300.flex.flex-col
        // Header del Plan
        .bg-gradient-to-r.from-blue-500.to-blue-600.px-6.py-8.text-white
          h2.text-2xl.font-bold.mb-2
            | Plan Básico
          p.text-blue-100.text-sm
            | Ideal para sitios pequeños o realizar pruebas rapidas
        // Precio
        .px-6.py-6.bg-gray-50
          .flex.items-baseline.gap-1
            span.text-4xl.font-bold.text-gray-900 Free
            span.text-gray-600.text-lg
              | /mes
          //p.text-sm.text-gray-500.mt-2
            | Facturación anual disponible con 10% de descuento
        // Características
        .flex-1.px-6.py-8
          ul.space-y-4
            li.flex.items-start.gap-3
              svg.w-5.h-5.text-green-500.flex-shrink-0(fill="currentColor" viewBox="0 0 20 20")
                path(fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd")
              span.text-gray-700
                | Hasta 5 escaneos mensuales
            
            li.flex.items-start.gap-3
              svg.w-5.h-5.text-green-500.flex-shrink-0(fill="currentColor" viewBox="0 0 20 20")
                path(fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd")
              span.text-gray-700
