extends ../dashboard-layout

block content
  // Header de la sección
  .bg-indigo-600.rounded-xl.p-8.text-white.shadow-lg.mb-8
    h1.text-3xl.font-bold Mis Escaneos
    p.text-indigo-100.mt-2 Gestiona y revisa el historial de seguridad de tus aplicaciones.        

  // Tabla de resultados
  div(class="flex flex-col mt-4")
    div(class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8")
      div(class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8")
        div(class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg bg-white")
          if scans && scans.length > 0
            table(class="min-w-full divide-y divide-gray-200")
              thead(class="bg-gray-50")
                tr
                  th(scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") Sitio Web
                  th(scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") Score
                  th(scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider") Fecha
                  th(scope="col" class="relative px-6 py-3")
                    span(class="sr-only") Acciones
              tbody(class="bg-white divide-y divide-gray-200")
                each scan in scans
                  tr(class="hover:bg-gray-50 transition-colors")
                    td(class="px-6 py-4 whitespace-nowrap")
                      div(class="text-sm font-medium text-gray-900") #{scan.url}
                    td(class="px-6 py-4 whitespace-nowrap")
                      // Lógica de color según el score
                      - let scoreColor = scan.score >= 80 ? 'bg-green-100 text-green-800' : (scan.score >= 50 ? 'bg-yellow-100 text-yellow-800' : 'bg-red-100 text-red-800')
                      span(class=`px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full ${scoreColor}`)
                        | #{scan.score} / 100
                    td(class="px-6 py-4 whitespace-nowrap text-sm text-gray-500")
                      | #{new Date(scan.created_at).toLocaleDateString('es-AR', { day: '2-digit', month: 'short', year: 'numeric' })}
                    td(class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-4")
                      a(href=`/scanner/${scan.id}` class="item_scan text-indigo-600 hover:text-indigo-900") Ver Reporte
                      button(
                        onclick=`confirmDelete('${scan.id}')` 
                        class="text-red-400 hover:text-red-600 transition-colors"
                      ) Eliminar
          else
            // Estado vacío
            div(class="text-center py-12")
              svg(class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor")
                path(vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z")
              h3(class="mt-2 text-sm font-medium text-gray-900") No hay escaneos

    // Script simple para el borrado
    script.
      function confirmDelete(id) {
        if (confirm('¿Estás seguro de que deseas eliminar este reporte? Esta acción no se puede deshacer.')) {
          fetch(`/scanner/${id}`, { 
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            }
          })
          .then(response => {
            if (response.ok) {
              window.location.href = '/dashboard/scans'; // Recarga la página para actualizar la lista
            } else {
              alert('Error al eliminar el escaneo');
            }
          })
          .catch(err => console.error('Error:', err));
        }
      }